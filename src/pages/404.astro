---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Seite nicht gefunden" description="Die von Ihnen angeforderte Seite konnte nicht gefunden werden." canonicalPath="/404">
  <section class="flex min-h-[50vh] flex-col items-center justify-center px-4 py-16 text-center">
    <h1 class="text-6xl font-bold text-primary-dark">404</h1>
    <p class="mt-4 text-xl text-muted">Seite nicht gefunden</p>
    <a href="/" class="btn btn-primary mt-8">Zurück zur Startseite</a>
  </section>
</BaseLayout>

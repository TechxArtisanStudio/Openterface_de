---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Anwendungsfälle"
  description="Praxisnahe Anwendungsfälle für Openterface KVM-over-USB-Produkte."
  canonicalPath="/use-cases/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Anwendungsfälle</h1>
      <p class="mt-4 text-lg text-muted">
        Openterface-Tools glänzen immer dann, wenn Sie einen Headless- oder schwer zugänglichen Computer ohne dedizierten
        Monitor und Tastatur steuern müssen.
      </p>
      <ul class="mt-8 space-y-4">
        {
          [
            'Begehungen von Rechenzentren und Colocation-Standorten',
            'Verwaltung von Homelab und NAS',
            'Inbetriebnahme von Embedded-Geräten und SBCs',
            'Wartung von Kiosken und Digital Signage',
            'IT-Außeneinsatz und Consulting-Projekte',
          ].map((item) => (
            <li class="card">{item}</li>
          ))
        }
      </ul>
      <a href={legacyPath('/use-cases/')} class="btn btn-secondary mt-8" target="_blank" rel="noopener">
        Vollständige Galerie der Anwendungsfälle ansehen →
      </a>
    </div>
  </section>
</BaseLayout>

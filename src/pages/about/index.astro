---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { legacyPath } from '../../config/site';
---

<BaseLayout
  title="Über Openterface"
  description="Erfahren Sie mehr über Openterface — Open-Source KVM-over-USB-Lösungen, entwickelt von TechxArtisan."
  canonicalPath="/about/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Über Openterface</h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Openterface entwickelt ultrakompakte Open-Source KVM-over-USB-Tools für IT-Profis, Entwickler und Maker.
        Vom Crowdfunding-Projekt Mini-KVM über den schlüsselbundgroßen KVM-GO bis hin zur programmierbaren KeyMod-Serie ist es unsere Mission,
        die Steuerung von Headless-Computern ohne sperrige Ausrüstung oder komplexe Netzwerke zu vereinfachen.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={legacyPath('/about/about-us/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Vollständiges Über uns →
        </a>
        <a href={legacyPath('/about/compliance/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Compliance →
        </a>
        <a href={legacyPath('/about/community/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Community →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

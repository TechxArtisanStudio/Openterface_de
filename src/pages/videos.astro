---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Videos"
  description="Openterface Produkt-Demos, Tutorials und Reviews auf YouTube."
  canonicalPath="/videos/"
>
  <DocLinkBanner message="Das vollständige, filterbare YouTube-Video-Grid befindet sich auf der alten Website, bis wir die Video-Pipeline portiert haben." />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl font-bold">Videos</h1>
      <p class="mt-4 text-lg text-muted">
        Sehen Sie sich Produkt-Demos, Einrichtungsanleitungen und Community-Reviews für Openterface KVM- und KeyMod-Produkte an.
      </p>
      <a href={legacyPath('/videos/')} class="btn btn-primary mt-8" target="_blank" rel="noopener">
        Alle Videos durchsuchen →
      </a>
    </div>
  </section>
</BaseLayout>
